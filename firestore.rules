rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Articles: authenticated users can read; admin writes via console
    match /articles/{articleId} {
      allow read: if request.auth != null;
    }

    // Vaccine Alerts: authenticated users can read; admin writes via console
    match /vaccine_alerts/{alertId} {
      allow read: if request.auth != null;
    }
  }
}
